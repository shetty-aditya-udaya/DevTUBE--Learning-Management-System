# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your_strong_secret_key_here_min_32_chars

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: MySQL (Aiven or any hosted MySQL)
DATABASE_URL=mysql+pymysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

# Option B: Local SQLite (for development)
# DATABASE_URL=sqlite:///devtube.db

# DB_HOST=your_db_host
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=your_db_name
# DB_PORT=3306

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_strong_jwt_secret_key_here_min_32_chars
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ── AI Assistant ──────────────────────────────────────────────────────────────
# Get your free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
